{
  "version": 2,
  "rewrites": [
    { "source": "/admin.html", "destination": "/frontend/admin.html" },
    { "source": "/admin", "destination": "/frontend/admin.html" },
    { "source": "/track.html", "destination": "/frontend/track.html" },
    { "source": "/track", "destination": "/frontend/track.html" },
    { "source": "/checkout.html", "destination": "/frontend/checkout.html" },
    { "source": "/checkout", "destination": "/frontend/checkout.html" },
    { "source": "/account.html", "destination": "/frontend/account.html" },
    { "source": "/account", "destination": "/frontend/account.html" },
    { "source": "/product.html", "destination": "/frontend/product.html" },
    { "source": "/product", "destination": "/frontend/product.html" },
    { "source": "/style.css", "destination": "/frontend/style.css" },
    { "source": "/app.js", "destination": "/frontend/app.js" },
    { "source": "/admin.js", "destination": "/frontend/admin.js" },
    { "source": "/demo-products.js", "destination": "/frontend/demo-products.js" },
    { "source": "/manifest.json", "destination": "/frontend/manifest.json" },
    { "source": "/service-worker.js", "destination": "/frontend/service-worker.js" },
    { "source": "/assets/:path*", "destination": "/frontend/assets/:path*" },
    { "source": "/favicon.ico", "destination": "/frontend/favicon.ico" },
    { "source": "/(.*)", "destination": "/frontend/index.html" }
  ]
}
